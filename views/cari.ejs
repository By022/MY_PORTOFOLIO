<div class="flex justify-center pt-16 gap-2">
    <input type="text" placeholder="Search..."
        class="focus:border-b-orange-300 font-action cursor-auto transition-all duration-300 focus:outline-none border-b-2 placeholder:px-2.5 px-2 py-1.5 w-1/2">
    <button type="submit" class="border cursor-pointer hover:bg-orange-600 text-white font-bold py-2 px-4">
        Search
    </button>
</div>
<button class="font-bold mode2 font-action text-center w-full hover:opacity-70 cursor-pointer pt-5 text-lg">Mode
    10+</button>
<script>
    const mode2 = document.querySelector('.mode2')
    mode2.addEventListener('click', () => {
        if (mode2.innerHTML === 'MODE 10+') {
            mode2.innerHTML = 'MODE 18+'
            mode2.classList.add('text-red-500')
            mode2.classList.remove('hover:opacity-70')
        } else {
            mode2.innerHTML = 'MODE 10+'
            mode2.classList.remove('text-red-500')
            mode2.classList.add('hover:opacity-70')
        }
    })
</script>
